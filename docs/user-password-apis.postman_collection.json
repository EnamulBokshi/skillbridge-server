{
  "info": {
    "name": "SkillBridge User Password APIs",
    "description": "Postman collection for Better Auth-based forgot/reset/change password endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "email",
      "value": "john.doe@example.com"
    },
    {
      "key": "redirectTo",
      "value": "http://localhost:3000/reset-password"
    },
    {
      "key": "resetToken",
      "value": "paste-token-from-url"
    },
    {
      "key": "currentPassword",
      "value": "oldpassword1234"
    },
    {
      "key": "newPassword",
      "value": "newpassword1234"
    }
  ],
  "item": [
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"redirectTo\": \"{{redirectTo}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/forgot-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "forgot-password"
          ]
        },
        "description": "Triggers Better Auth requestPasswordReset and sends a reset link email."
      }
    },
    {
      "name": "Reset Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\",\n  \"confirmPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/reset-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "reset-password"
          ]
        },
        "description": "Consumes Better Auth reset token and sets a new password."
      }
    },
    {
      "name": "Change Password (Logged In)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"{{currentPassword}}\",\n  \"newPassword\": \"{{newPassword}}\",\n  \"confirmPassword\": \"{{newPassword}}\",\n  \"revokeOtherSessions\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/change-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "change-password"
          ]
        },
        "description": "Requires active auth session cookie in Postman."
      }
    }
  ]
}
